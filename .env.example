# commonplace — environment template.
# Copy to `.env` ON THE HOST and fill in real values:  cp .env.example .env
# `.env` is gitignored and must NEVER be committed — every secret lives here only.

# --- Personal tier extraction ---
# DEFAULT: fully local (mistral:7b via Ollama). commonplace is offline-first — no key,
# nothing leaves the box. Leave the block below commented for the default.
#
# OPT IN to a HOSTED model for the personal tier only if the data is NOT confidential
# (better graph quality, costs pennies). Uncomment and fill in:
#PERSONAL_LLM_PROVIDER=anthropic
#PERSONAL_LLM_MODEL=claude-haiku-4-5
#PERSONAL_SEMAPHORE_LIMIT=5
#ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- FalkorDB (shared graph store) ---
# Generate a strong value:  openssl rand -hex 24
FALKORDB_PASSWORD=change-me-to-a-long-random-string

# --- Ollama (shared 768-dim embedder + local extraction model) ---
# Reached from INSIDE the MCP containers via the Docker host gateway (see compose extra_hosts).
OLLAMA_API_URL=http://host.docker.internal:11434/v1

# --- FalkorDB browser UI (1 = enabled) ---
BROWSER=1

# --- Gateway: per-tier bearer tokens ---
# Clients send `Authorization: Bearer <token>`. Separate tokens enforce tier
# isolation: give a confidential client only CLIENT_TOKEN and it cannot reach the
# personal (hosted-extraction) endpoint. Generate strong values:  openssl rand -hex 32
PERSONAL_TOKEN=change-me-personal-bearer-token
CLIENT_TOKEN=change-me-client-bearer-token
